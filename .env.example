# ──────────────────────────────────────────────
# ARK AI Bot — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# Supabase project credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# HuggingFace API token (needs access to the model below)
HF_API_TOKEN=hf_your-huggingface-token

# LLM model selection (switch without code changes)
# Primary:     Qwen/Qwen2.5-72B-Instruct
# Alternative: meta-llama/Llama-3.3-70B-Instruct
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# AiSensy WhatsApp integration
# AISENSY_API_KEY         = Project API password (short hex)
# AISENSY_CAMPAIGN_API_KEY= Campaign API JWT (long eyJ... token)
# These are DIFFERENT — copy both from AiSensy → Manage → API Keys.
AISENSY_API_KEY=your-aisensy-project-api-key
AISENSY_CAMPAIGN_API_KEY=your-aisensy-campaign-jwt
AISENSY_PROJECT_ID=your-aisensy-project-id
AISENSY_CAMPAIGN_NAME=your-campaign-name

# Admin WhatsApp number for escalation notifications (e.g. 919876543210)
ADMIN_WHATSAPP_NUMBER=919xxxxxxxxx

# Zapier webhook for Google Sheets lead storage
ZAPIER_WEBHOOK_URL=

# Redis URL (optional — leave empty to use in-memory cache)
REDIS_URL=
